<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="plugin.program.bizzlewizard" name="[COLOR skyblue]Bizzle[/COLOR]Wizard" version="2.0.7" provider-name="bizzlebuild">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
        <import addon="script.module.requests" />
        <import addon="script.module.six" />
        <import addon="script.kodi.android.update" optional="true" version="1.1.7" />
        <import addon="script.speedtester" optional="true" version="1.1.2" />
    </requires>

    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>executable</provides>
    </extension>

    <extension point="xbmc.service" library="startup.py" start="startup" />

    <extension point="xbmc.addon.metadata">
        <summary lang="en">[COLOR skyblue]Bizzle[/COLOR]Wizard</summary>
        <description lang="en">[COLOR skyblue]bizzle[/COLOR]Wizard offers many maintenance features, selective add-on data saving, and automated build installs.</description>
        <platform>all</platform>
        <reuselanguageinvoker>false</reuselanguageinvoker>
        <source>https://www.github.com/bizzlebuild/plugin.program.bizzlewizard/</source>
        <news>
2.0.7
 - Fix Error when using default log settings
2.0.6
 - Fix regex for formatting tags
 - Fix theme selection after build install
 - Fix downloading into invalid path
2.0.5
 - Add Enable All Add-ons after Build Install
 - Initial Commit
        </news>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.png</fanart>
        </assets>
    </extension>
</addon>

<addon id="repository.bizzle" name="bizzle repository" version="1.0" provider-name="bizzle builds">
    <extension point="xbmc.addon.repository" name="bizzle Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/bizzlebuild/bizzlebuild.github.io/master/repo/zips/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/bizzlebuild/bizzlebuild.github.io/master/repo/zips/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/bizzlebuild/bizzlebuild.github.io/master/repo/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>bizzle repository</summary>
        <description>For kodi builds from Bizzle</description>
        <disclaimer></disclaimer>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
</addons>
